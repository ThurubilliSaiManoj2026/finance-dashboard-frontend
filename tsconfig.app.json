{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode — Vite handles module resolution */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict type-checking */
    "strict": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases — baseUrl is NOT needed in TypeScript 5+ with moduleResolution: bundler.
       paths alone is sufficient and avoids the VS Code schema validation error. */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}